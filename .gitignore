# Dependencies
node_modules/

# Turborepo
.turbo/

# Next.js
.next/
.next-e2e/
.next-prod/

# Build outputs
dist/

# Gateway vendored xterm assets (regenerated by postinstall)
apps/terminal-gateway/public/vendor/

# Gateway session metadata (runtime data, not checked in)
data/

# Gateway server registry (config next to .env, key-based ssh; never checked in)
servers.json
apps/terminal-gateway/servers.json

# Gateway push subscription store (device endpoints + keys; never checked in)
push-subscriptions.json
apps/terminal-gateway/push-subscriptions.json

# Gateway push settings (runtime prefs: duration threshold + job-start toggle)
push-settings.json
apps/terminal-gateway/push-settings.json

# Playwright
test-results/
playwright-report/
playwright/.cache/

# Coverage
coverage/

# Misc
*.log
.DS_Store
.env
.env.local
.env*.local
# Docker env (real secrets); the *.example template stays checked in.
.env.docker
!.env.docker.example

# TypeScript incremental build info
*.tsbuildinfo

# graphify knowledge-graph output (regenerate with graphify_azure.py)
graphify-out/

# CI workflows and git hooks (kept out of the public repo)
.github/workflows/
.husky/

# agent-service chat history (per-chat JSONL)
apps/agent-service/data/
