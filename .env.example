# ─────────────────────────────────────────────────────────────────────────────
# Local-production stack endpoint (consumed by ecosystem.config.cjs + build-prod.sh)
# Copy to `.env` and edit. Secrets/auth still live in each app's own .env.
# ─────────────────────────────────────────────────────────────────────────────

# PUBLIC_ORIGIN — the single origin the whole stack is served on. It is baked
# into the frontend at build time AND added to the gateway/agent allowlists, so
# switching local ↔ tunnel is JUST this one line (then rebuild + pm2 restart):
#
#   Local, same machine only:   http://localhost:3110   (open the proxy directly)
#   Public loclx tunnel:        https://sparklab.ap.loclx.io
#
PUBLIC_ORIGIN=https://sparklab.ap.loclx.io

# TUNNEL_* — the loclx tunnel fronting the proxy. Set TUNNEL_ENABLED=false for
# local-only runs (the prod-tunnel PM2 app is then skipped entirely). When
# enabled, PUBLIC_ORIGIN must equal https://<SUBDOMAIN>.<REGION>.loclx.io.
TUNNEL_ENABLED=true
TUNNEL_SUBDOMAIN=sparklab
TUNNEL_REGION=ap
