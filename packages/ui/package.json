  },
  "devDependencies": {
    "@sparklab/config-eslint": "workspace:*",
    "@sparklab/config-typescript": "workspace:*",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "eslint": "^9.29.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.10",
    "typescript": "^5.8.3"
  },
