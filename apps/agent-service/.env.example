# Azure OpenAI (AI Foundry) — copy to .env and fill in. .env is gitignored.
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<secret>
AZURE_OPENAI_API_VERSION=2025-04-01-preview
GPT56SOL_DEPLOYMENT=gpt-5.6-sol

# Agent service
AGENT_PORT=3009
GATEWAY_URL=http://127.0.0.1:3007
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:3003

# Credentials the service uses to log in to the gateway (match the gateway's).
GATEWAY_AUTH_USER=admin
GATEWAY_AUTH_PASSWORD=<gateway-password>
