{
  "name": "@sparklab/terminal-gateway",
  "version": "0.1.0",
  "description": "Web terminal where jobs survive browser and gateway restarts, backed by tmux",
  "type": "module",
  "scripts": {
    "smoke": "node test/smoke-pty-tmux.js",
    "acceptance": "node test/acceptance-survive-disconnect.js",
    "acceptance:multi": "node test/acceptance-multi-session.js",
    "acceptance:remote": "node test/acceptance-remote-survive.js",
    "test:servers-password": "node test/servers-password-auth.js",
    "test:agent-endpoints": "node test/agent-endpoints.js",
    "test:fs": "node test/fs-endpoints.js",
    "test:git": "node test/git-endpoints.js",
    "hash-password": "node scripts/hash-password.js",
    "dev": "node --env-file-if-exists=.env --watch src/server.js",
    "start": "node --env-file-if-exists=.env src/server.js"
  },
  "dependencies": {
    "node-pty": "^1.0.0",
    "ws": "^8.18.0"
  }
}
