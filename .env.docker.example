# ─────────────────────────────────────────────────────────────────────────────
# Sparklab Terminal — Docker environment. Copy to `.env.docker` and edit.
# Consumed by docker-compose.yml (env_file + PUBLIC_ORIGIN build/runtime arg).
# .env.docker is gitignored (matches .env* rules). Never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ---- Public origin (REQUIRED to match how you reach the app) ----------------
# The single origin the browser loads the app from. Baked into the frontend at
# BUILD time AND used at runtime for the CSRF/cookie allowlist. Change it, then
# `docker compose up -d --build` to re-bake.
#   Local, same machine:        http://localhost:3110
#   Behind TLS reverse proxy:   https://terminal.example.com
PUBLIC_ORIGIN=http://localhost:3110

# Host port published for the in-container proxy (:3110). Change to avoid a
# clash with the native local-prod stack (which also uses 3110).
HOST_PORT=3110

# ---- Auth (REQUIRED — the app is unusable without a login) -------------------
GATEWAY_AUTH_USER=admin
# Dev/simple: plaintext password (hashed at startup).
GATEWAY_AUTH_PASSWORD=changeme
# Production: a scrypt hash instead of the plaintext above. Generate with:
#   pnpm --filter @sparklab/terminal-gateway hash-password
# GATEWAY_AUTH_PASSWORD_HASH=scrypt$...

# (The agent reuses GATEWAY_AUTH_USER / GATEWAY_AUTH_PASSWORD above to log in to
# the gateway — both processes read the same container env, so no duplication.)

# Set to 1 ONLY when an external https reverse proxy (Caddy/nginx/ingress) fronts
# the container. Marks the session cookie Secure + honors X-Forwarded-*. Leave
# unset for plain-http localhost or login breaks.
# TRUST_PROXY=1

# ---- Agent Chat (OPTIONAL — needed for the AI panel) ------------------------
# The agent process starts ONLY when AZURE_OPENAI_ENDPOINT is set (it exits
# FATAL without it, so pm2 skips it entirely when unconfigured). Without these
# the terminal stack runs fine; the Agent Chat panel is just unavailable.
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
# AZURE_OPENAI_API_KEY=<secret>
# AZURE_OPENAI_API_VERSION=2025-04-01-preview
# GPT56SOL_DEPLOYMENT=gpt-5.6-sol

# ---- Web Push "job finished" notifications (OPTIONAL) ------------------------
# Absent => push is simply disabled. Generate a STABLE keypair with:
#   pnpm --filter @sparklab/terminal-gateway generate-vapid
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@example.com

# Note: the virtual browser (Browser Use) is intentionally NOT bundled in this
# image. BROWSER_USE_PROJECT is unset, so browser tools stay disabled; the rest
# of Agent Chat works. See docs/DOCKER.md.
